{
  "name": "paw-meet-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "api:generate": "openapi --input ./generated/openapi.yaml --output ./generated/api-client --client fetch --useUnionTypes",
    "api:generate:clean": "rm -rf ./generated/api-client && npm run api:generate",
    "api:check": "test -f ./generated/api-client/index.ts"
  },
  "dependencies": {
    "next": "16.2.3",
    "postcss": "^8.5.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "openapi-typescript-codegen": "^0.29.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}
